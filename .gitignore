# Local .terraform directories
**/.terraform/*

# State files - these live in S3, never commit them
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files can contain sensitive data
*.tfvars
*.tfvars.json
!example.tfvars

# CLI config files
.terraformrc
terraform.rc

# Plan output
*.tfplan

# OS / editor
.DS_Store
.idea/
.vscode/
